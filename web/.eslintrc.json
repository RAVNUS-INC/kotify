{
  "extends": [
    "next/core-web-vitals",
    "plugin:jsx-a11y/strict",
    "prettier"
  ],
  "rules": {
    "@next/next/no-html-link-for-pages": "off",
    "jsx-a11y/no-autofocus": ["error", { "ignoreNonDOM": true }],
    "jsx-a11y/label-has-associated-control": [
      "error",
      { "assert": "either" }
    ]
  }
}
